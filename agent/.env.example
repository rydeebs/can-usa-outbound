# CAN USA Email Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — only .env.example is committed.

# ── Anthropic ──────────────────────────────────────────────────────────────
# Get this from console.anthropic.com → API keys → Create key
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Microsoft Azure ────────────────────────────────────────────────────────
# From portal.azure.com → App registrations → your CAN USA Agent app
# Application (client) ID on the app overview page
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Directory (tenant) ID on the same overview page
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NO client secret needed — delegated auth uses token_cache.json instead
# Run 'python auth.py' once to generate token_cache.json

# ── Email ──────────────────────────────────────────────────────────────────
# The Microsoft 365 account the agent sends from
SENDER_EMAIL=pawel@canusa.com

# ── Agent behaviour ────────────────────────────────────────────────────────
# Set to true only after 30+ days of reviewing Claude's replies in the queue
AUTO_SEND=false
# How often the agent checks Pawel's inbox for new replies (minutes)
POLL_INTERVAL_MINUTES=15
# Minimum evaluator score (1-10) before a draft is auto-approved
# Drafts below this always go to the review queue regardless of AUTO_SEND
MIN_AUTO_SEND_SCORE=8

# ── LinkedIn via your MCP server ──────────────────────────────────────────
# The app never stores LinkedIn credentials; it calls your remote MCP server.
LINKEDIN_MCP_SERVER_URL=https://...
LINKEDIN_MCP_API_KEY=...
LINKEDIN_MCP_AUTO_CONNECT=true
LINKEDIN_MCP_LIST_NAME=CAN USA LinkedIn Outreach
LINKEDIN_MCP_CAMPAIGN_NAME=CAN USA LinkedIn Outreach
# Optional: set exact MCP tool names if auto-discovery needs help.
# LINKEDIN_MCP_CONTACT_TOOL=
# LINKEDIN_MCP_CONNECT_TOOL=
# LINKEDIN_MCP_LIST_TOOL=
